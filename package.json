{
  "name": "blogy-landing",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "prestart": "node scripts/generate-runtime-env.js",
    "start": "react-scripts start",
    "prebuild": "node scripts/generate-runtime-env.js",
    "build": "react-scripts build",
    "postbuild": "node scripts/generate-sitemap.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "generate": "node scripts/generate-startup-names.js"
  },
  "reactSnap": {
    "source": "build",
    "destination": "build",
    "include": ["/", "/startup-names"],
    "crawl": true,
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "puppeteerExecutablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "headless": true
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.10",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.2.2"
  }
}
